---

<Layout title={`${service.title} | Servicios Arrancandonga`}>
    <div class="min-h-screen pt-4 md:pt-6 pb-8 md:pb-12 px-4 bg-cream w-full overflow-hidden flex flex-col">
        <Header />
        <div class="grain"></div>
        <div class="max-w-6xl mx-auto flex-grow relative z-10 w-full">
            <a href="/" class="inline-block mb-6 md:mb-8 font-display font-bold text-brandDark/90 hover:text-brandOrange flex items-center gap-2 transition-colors text-sm md:text-base w-max">
                ← Volver al inicio
            </a>

            {/* Header modular con decoraciones */}
            <div class="relative mb-8">
                <div class="absolute -top-10 -right-10 w-20 h-20 animate-float hidden md:block z-0 opacity-50 text-brandYellow">
                    <Icon name="Star" />
                </div>
                <div class={`${service.color} rounded-3xl md:rounded-[3rem] p-8 md:p-16 border-4 border-brandDark text-center relative overflow-hidden transform hover:scale-[1.02] transition-transform duration-500`}>
                    <div class="absolute top-4 left-4 w-8 h-8 bg-white/30 rounded-full animate-pulse"></div>
                    <div class="absolute bottom-4 right-4 w-12 h-12 bg-white/20 rounded-full"></div>
                    <div class="absolute top-1/2 right-8 w-4 h-4 bg-brandDark rounded-full hidden md:block"></div>

                    <div class="w-24 h-24 md:w-32 md:h-32 mx-auto mb-6 relative z-10 animate-float" style="animation-duration: 4s;">
                        <Icon name={service.iconName as any} />
                    </div>
                    <h1 class="font-display text-3xl md:text-5xl lg:text-6xl font-bold text-brandDark mb-4 relative z-10">{service.title}</h1>
                    <p class="text-lg md:text-2xl text-brandDark/90 font-medium relative z-10 max-w-3xl mx-auto leading-tight">{content.headline}</p>

                    {/* Precio flotante */}
                    <div class="mt-6 inline-block bg-white rounded-full px-6 py-2 border-3 border-brandDark shadow-lg transform rotate-1 hover:rotate-0 transition-transform">
                        <span class="font-bold text-brandDark">{content.price}</span>
                    </div>
                </div>
            </div>

            {/* Introducción */}
            {['branding', 'identidad', 'web'].includes(service.id) ? (
                <div class="max-w-4xl mx-auto text-center mb-16 space-y-6 md:space-y-8 px-4">
                    {service.id === 'branding' && (
