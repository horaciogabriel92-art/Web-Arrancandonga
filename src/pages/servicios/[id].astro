                                </ul>
                                <div class="bg-cream rounded-2xl p-4 border-2 border-brandDark/20">
                                    <p class="text-sm font-bold text-brandDark">Cada pieza se diseña alineada a tu identidad visual para mantener coherencia y profesionalismo.</p>
                                </div>
                            </div>
                        </div>
                    ) : service.id === 'marketing' ? (
                        <div class="grid md:grid-cols-2 gap-6">
                            {content.steps.map((step: any, idx: number) => {
                                const colors = ['bg-brandYellow', 'bg-brandPink', 'bg-brandBlue', 'bg-brandLavender'];
                                const color = colors[idx % 4];
                                const icons = ['💡', '🔍', '🎯', '🚀'];
                                const icon = icons[idx % 4];
                                
                                // Parsear descripción para separar texto introductorio de bullets
                                const lines = step.desc.split('\n');
                                const introLines = [];
                                const bulletLines = [];
                                let foundBullets = false;
                                let afterBullets = [];
                                
                                for (const line of lines) {
                                    const trimmed = line.trim();
                                    if (trimmed.startsWith('•')) {
                                        foundBullets = true;
                                        bulletLines.push(trimmed.replace('•', '').trim());
                                    } else if (foundBullets && trimmed.length > 0 && !trimmed.startsWith('•')) {
                                        afterBullets.push(trimmed);
                                    } else if (!foundBullets && trimmed.length > 0) {
                                        introLines.push(trimmed);
                                    }
                                }
                                
                                return (
                                    <div class={`${color} rounded-[2rem] p-6 md:p-8 border-4 border-brandDark shadow-[6px_6px_0px_#27272A] hover:shadow-[10px_10px_0px_#27272A] transform hover:-translate-y-2 transition-all duration-300 relative overflow-hidden flex flex-col h-full group`}>
                                        {/* Número decorativo */}
                                        <div class="absolute -right-4 -top-4 w-20 h-20 bg-white/40 rounded-full flex items-center justify-center border-3 border-brandDark transform group-hover:scale-110 transition-transform">
                                            <span class="font-display font-bold text-3xl text-brandDark">{idx + 1}</span>
                                        </div>
                                        
                                        {/* Icono */}
                                        <div class="mb-4 relative z-10">
                                            <span class="text-4xl">{icon}</span>
                                        </div>
                                        
                                        {/* Título */}
                                        <h4 class="font-display font-bold text-xl md:text-2xl text-brandDark mb-4 relative z-10 pr-12">{step.title}</h4>
                                        
                                        {/* Descripción introductoria */}
                                        {introLines.length > 0 && (
                                            <p class="text-brandDark/90 text-sm md:text-base font-medium mb-4 relative z-10 leading-relaxed">
                                                {introLines.join(' ')}
                                            </p>
                                        )}
                                        
                                        {/* Bullets con diseño */}
                                        {bulletLines.length > 0 && (
                                            <div class="bg-white/60 rounded-2xl p-4 border-2 border-brandDark/30 mb-4">
                                                <ul class="space-y-2">
                                                    {bulletLines.map((bullet: string, i: number) => (
                                                        <li class="flex items-start gap-2 text-sm text-brandDark">
                                                            <span class="text-brandOrange font-bold flex-shrink-0">•</span>
                                                            <span class="leading-snug">{bullet}</span>
                                                        </li>
                                                    ))}
                                                </ul>
                                            </div>
                                        )}
                                        
                                        {/* Texto final (después de bullets) */}
                                        {afterBullets.length > 0 && (
                                            <p class="text-brandDark/90 text-sm md:text-base italic relative z-10 mt-auto pt-2">
                                                {afterBullets.join(' ')}
                                            </p>
                                        )}
                                        
                                        {/* Resultado si existe */}
                                        {step.result && (
                                            <div class="mt-4 bg-white rounded-xl p-3 border-2 border-brandDark/20 text-sm font-medium text-brandDark relative z-10">
                                                {step.result}
                                            </div>
                                        )}
                                    </div>
                                );
                            })}
                        </div>
                    ) : (
                        <div class="grid md:grid-cols-2 gap-6">
                            {content.steps.map((step: any, idx: number) => {
                                const accentColors = ['bg-brandYellow', 'bg-brandPink', 'bg-brandBlue', 'bg-brandOrange'];
                                const accentColor = accentColors[idx % 4];
                                const icons = ['🔍', '📍', '🎨', '📋'];
                                const icon = icons[idx % 4];
                                
                                // Parse description
                                const lines = step.desc.split('\n');
                                const introText = lines.filter((l: string) => !l.trim().startsWith('•') && l.trim().length > 0).join(' ');
                                const bullets = lines.filter((l: string) => l.trim().startsWith('•')).map((l: string) => l.replace('•', '').trim());
                                
                                // Parse result
                                const resultLines = step.result ? step.result.split('\n').filter((l: string) => l.trim().length > 0) : [];
                                const resultTitle = resultLines.length > 0 ? resultLines[0] : '';
                                const resultText = resultLines.length > 1 ? resultLines.slice(1).join(' ') : '';
                                
                                return (
                                    <div class="bg-white rounded-3xl p-6 md:p-8 border-4 border-brandDark shadow-[6px_6px_0px_#27272A] hover:shadow-[10px_10px_0px_#27272A] transform hover:-translate-y-2 transition-all duration-300 relative overflow-hidden flex flex-col h-full group">
                                        {/* Header con icono y número */}
                                        <div class="flex items-start justify-between mb-4">
                                            <div class={`w-14 h-14 ${accentColor} rounded-2xl border-3 border-brandDark flex items-center justify-center transform group-hover:scale-110 transition-transform duration-300 shadow-sm`}>
                                                <span class="text-2xl">{icon}</span>
                                            </div>
                                            <span class="font-display font-bold text-4xl text-brandDark/10 select-none">0{idx + 1}</span>
                                        </div>
                                        
                                        {/* Título */}
                                        <h4 class="font-display font-bold text-xl text-brandDark mb-3">{step.title}</h4>
                                        
                                        {/* Descripción intro */}
                                        {introText && (
                                            <p class="text-brandDark/80 text-sm font-medium mb-4 leading-relaxed">{introText}</p>
                                        )}
                                        
                                        {/* Bullets */}
                                        {bullets.length > 0 && (
                                            <ul class="space-y-2 mb-4 flex-grow">
                                                {bullets.map((bullet: string, i: number) => (
                                                    <li class="flex items-start gap-2 text-sm text-brandDark/90">
                                                        <span class={`w-5 h-5 ${accentColor} rounded-full border-2 border-brandDark flex items-center justify-center flex-shrink-0 text-xs font-bold`}>✓</span>
                                                        <span class="leading-snug">{bullet}</span>
                                                    </li>
                                                ))}
                                            </ul>
                                        )}
                                        
                                        {/* Resultado */}
                                        {step.result && (
                                            <div class={`mt-auto ${accentColor}/20 rounded-2xl p-4 border-2 border-brandDark/30 relative overflow-hidden`}>
                                                <div class={`absolute -right-2 -top-2 w-8 h-8 ${accentColor} rounded-full border-2 border-brandDark flex items-center justify-center text-sm`}>🎯</div>
                                                <p class="text-brandDark font-bold text-sm mb-1">{resultTitle}</p>
                                                <p class="text-brandDark/80 text-xs leading-relaxed">{resultText}</p>
                                            </div>
                                        )}
                                    </div>
                                );
                            })}
                        </div>
                    )}
                </div>
            )}

            {/* Tarjeta de beneficios con rotación (ahora debajo de los pasos) */}
            {content.afterProcess && content.afterProcess.length > 0 && (
                <div class="bg-brandYellow rounded-3xl p-6 md:p-10 border-4 border-brandDark shadow-lg transform -rotate-1 hover:rotate-0 hover:scale-[1.02] transition-all duration-300 mb-8">
                    <h3 class="font-bold text-2xl md:text-3xl mb-6 text-brandDark text-center flex items-center justify-center gap-3">
                        <span class="text-4xl">✨</span> ¿Qué cambia después?
                    </h3>
                    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
                        {content.afterProcess.map((item: string) => (
                            <div class="bg-white/80 rounded-2xl p-4 border-2 border-brandDark/20 flex items-start gap-3 transform hover:scale-105 transition-transform">
                                <span class="text-2xl flex-shrink-0">✓</span>
                                <span class="font-medium text-brandDark text-sm md:text-base">{item}</span>
                            </div>
                        ))}
                    </div>
                </div>
            )}

            {/* Lista de includes para web */}
            {content.includes && (
                <div class="bg-brandLavender rounded-3xl p-6 md:p-10 border-4 border-brandDark shadow-lg transform hover:scale-[1.01] transition-all duration-300 mb-8">
                    <h3 class="font-bold text-2xl md:text-3xl mb-6 text-brandDark text-center">Todas nuestras webs incluyen</h3>
                    <div class="grid sm:grid-cols-2 gap-4">
                        {content.includes.map((item: string) => (
                            <div class="flex items-center gap-3 bg-white/60 rounded-xl p-3 border-2 border-brandDark/20">
                                <span class="text-brandGreen"><Icon name="Check" /></span>
                                <span class="font-medium text-brandDark text-sm md:text-base">{item}</span>
                            </div>
                        ))}
                    </div>
                </div>
            )}

            {/* FAQ */}
            {content.faq && (
                <div class="bg-white rounded-3xl p-6 md:p-10 border-4 border-brandDark shadow-lg mb-8">
                    <h3 class="font-bold text-2xl md:text-3xl mb-6 text-brandDark text-center">Preguntas frecuentes</h3>
                    <div class="space-y-4">
                        {content.faq.map((item: any) => (
                            <div class="border-b-2 border-brandDark/10 pb-4 last:border-0 last:pb-0">
                                <p class="font-bold text-brandDark text-base md:text-lg mb-1 flex items-center gap-2">
                                    <span class="text-brandOrange">•</span> {item.q}
                                </p>
                                <p class="text-brandDark/70 text-sm md:text-base pl-6">{item.a}</p>
                            </div>
                        ))}
                    </div>
                </div>
            )}

            {/* CTA Final */}
            <div class={`${service.id === 'branding' || service.id === 'marketing' ? 'bg-brandYellow text-brandDark' : service.id === 'identidad' ? 'bg-brandPink text-brandDark' : service.id === 'web' ? 'bg-brandBlue text-white' : service.id === 'pack' ? 'bg-brandLavender text-brandDark' : service.id === 'social' ? 'bg-brandOrange text-brandDark' : service.id === 'ads' ? 'bg-brandPink text-brandDark' : service.id === 'diseno' ? 'bg-brandOlive text-brandDark' : 'bg-brandPurple text-white'} rounded-3xl md:rounded-[3rem] p-8 md:p-16 border-4 border-brandDark text-center shadow-2xl relative overflow-hidden transform hover:scale-[1.02] transition-all duration-500`}>
                {service.id === 'branding' ? (
                    <>
                        <div class="absolute top-4 left-4 w-16 h-16 bg-white/30 rounded-full animate-pulse"></div>
                        <div class="absolute bottom-4 right-4 w-24 h-24 bg-white/20 rounded-full"></div>
                        <div class="absolute top-1/2 left-8 w-4 h-4 bg-brandDark rounded-full hidden md:block animate-float"></div>
                    </>
                ) : service.id === 'identidad' ? (
                    <>
                        <div class="absolute top-4 left-4 w-20 h-20 bg-white/30 rounded-full animate-pulse"></div>
                        <div class="absolute bottom-4 right-4 w-32 h-32 bg-white/20 rounded-full"></div>
                        <div class="absolute top-1/2 left-8 w-4 h-4 bg-brandDark rounded-full hidden md:block animate-float"></div>
                    </>
                ) : service.id === 'web' ? (
                    <>
                        <div class="absolute top-8 left-8 w-24 h-24 bg-white/10 rounded-full"></div>
                        <div class="absolute bottom-8 right-8 w-40 h-40 bg-white/10 rounded-full"></div>
                        <div class="absolute top-1/2 left-12 w-4 h-4 bg-brandYellow rounded-full hidden md:block animate-pulse"></div>
                    </>
                ) : service.id === 'social' ? (
                    <>
                        <div class="absolute top-6 left-6 w-20 h-20 bg-white/20 rounded-full animate-pulse"></div>
                        <div class="absolute bottom-6 right-6 w-28 h-28 bg-white/15 rounded-full"></div>
                        <div class="absolute top-1/2 left-10 w-4 h-4 bg-brandDark rounded-full hidden md:block animate-float"></div>
                    </>
                ) : service.id === 'ads' ? (
                    <>
                        <div class="absolute top-6 left-6 w-20 h-20 bg-white/20 rounded-full animate-pulse"></div>
                        <div class="absolute bottom-6 right-6 w-28 h-28 bg-white/15 rounded-full"></div>
                        <div class="absolute top-1/2 left-10 w-4 h-4 bg-brandDark rounded-full hidden md:block animate-float"></div>
                    </>
                ) : service.id === 'diseno' ? (
                    <>
                        <div class="absolute top-6 left-6 w-20 h-20 bg-white/20 rounded-full animate-pulse"></div>
                        <div class="absolute bottom-6 right-6 w-28 h-28 bg-white/15 rounded-full"></div>
                        <div class="absolute top-1/2 left-10 w-4 h-4 bg-brandDark rounded-full hidden md:block animate-float"></div>
                    </>
                ) : (
                    <>
                        <div class="absolute top-4 left-4 w-20 h-20 bg-white/10 rounded-full animate-pulse"></div>
                        <div class="absolute bottom-4 right-4 w-32 h-32 bg-white/10 rounded-full"></div>
                        <div class="absolute top-1/2 left-8 w-4 h-4 bg-brandYellow rounded-full hidden md:block animate-float"></div>
                    </>
                )}

                <p class="text-lg md:text-2xl font-medium mb-8 whitespace-pre-line relative z-10 leading-relaxed max-w-4xl mx-auto">{content.cta}</p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center relative z-10">
                    <a href="https://calendly.com/arrancandonga-estudiocreativo/conocernos-mejor" target="_blank" class={`inline-flex items-center justify-center gap-2 bg-white ${service.id === 'branding' || service.id === 'identidad' || service.id === 'pack' || service.id === 'social' || service.id === 'ads' || service.id === 'diseno' || service.id === 'marketing' ? 'text-brandDark' : service.id === 'web' ? 'text-brandBlue' : 'text-brandPurple'} px-8 py-4 rounded-full font-display font-bold btn-lineal text-base md:text-lg shadow-lg hover:shadow-xl`}>
                        <Icon name="Calendar" /> <span>Agendar reunión</span>
                    </a>
                    <a href="https://wa.me/59899928009" target="_blank" class="inline-flex items-center justify-center gap-2 bg-[#25D366] text-white px-8 py-4 rounded-full font-display font-bold text-base md:text-lg shadow-lg hover:shadow-xl border-2 border-transparent hover:border-white transition-colors">
                        <Icon name="WhatsApp" /> <span>Escribir por WhatsApp</span>
                    </a>
                </div>
            </div>
            
            {/* Servicios que potencian la publicidad - Solo para Ads */}
            {service.id === 'ads' && (
                <div class="max-w-4xl mx-auto mt-12 px-4">
                    <h3 class="font-bold text-2xl md:text-3xl mb-8 text-brandDark text-center">
                        Servicios que potencian la publicidad
                    </h3>
                    
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        {/* Producción de contenido */}
                        <a href="/servicios/social" class="bg-white rounded-2xl p-5 border-4 border-brandDark shadow-lg hover:shadow-xl transform hover:-translate-y-2 transition-all duration-300 text-center group">
                            <div class="w-14 h-14 bg-brandOrange rounded-xl border-2 border-brandDark flex items-center justify-center mb-4 mx-auto transform group-hover:scale-110 transition-transform">
                                <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                                    <circle cx="8.5" cy="8.5" r="1.5"/>
                                    <polyline points="21 15 16 10 5 21"/>
                                </svg>
                            </div>
                            <h4 class="font-bold text-lg text-brandDark mb-2">Producción de contenido</h4>
                            <p class="text-brandDark/70 text-sm">Para crear anuncios</p>
                        </a>
                        
                        {/* Desarrollo web */}
                        <a href="/servicios/web" class="bg-white rounded-2xl p-5 border-4 border-brandDark shadow-lg hover:shadow-xl transform hover:-translate-y-2 transition-all duration-300 text-center group">
                            <div class="w-14 h-14 bg-brandBlue rounded-xl border-2 border-brandDark flex items-center justify-center mb-4 mx-auto transform group-hover:scale-110 transition-transform">
                                <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
                                    <line x1="8" y1="21" x2="16" y2="21"/>
                                    <line x1="12" y1="17" x2="12" y2="21"/>
                                </svg>
                            </div>
                            <h4 class="font-bold text-lg text-brandDark mb-2">Desarrollo web</h4>
                            <p class="text-brandDark/70 text-sm">Para dirigir tráfico</p>
                        </a>
                        
                        {/* Asesoría en marketing */}
                        <a href="/servicios/marketing" class="bg-white rounded-2xl p-5 border-4 border-brandDark shadow-lg hover:shadow-xl transform hover:-translate-y-2 transition-all duration-300 text-center group">
                            <div class="w-14 h-14 bg-brandYellow rounded-xl border-2 border-brandDark flex items-center justify-center mb-4 mx-auto transform group-hover:scale-110 transition-transform">
                                <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="18" y1="20" x2="18" y2="10"/>
                                    <line x1="12" y1="20" x2="12" y2="4"/>
                                    <line x1="6" y1="20" x2="6" y2="14"/>
                                </svg>
                            </div>
                            <h4 class="font-bold text-lg text-brandDark mb-2">Asesoría en marketing</h4>
                            <p class="text-brandDark/70 text-sm">Para definir estrategia</p>
                        </a>
                    </div>
                </div>
            )}
        </div>
    </div>
    <Footer />
</Layout>
