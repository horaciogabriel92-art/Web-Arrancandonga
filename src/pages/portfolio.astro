---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
import { projectsData } from '../data/projectsData.js';

const categories = [
    { id: 'todos', name: 'Todos' },
    { id: 'identidad', name: 'Identidad Visual' },
    { id: 'web', name: 'Desarrollo Web' },
    { id: 'social', name: 'Social Media' }
];

const categoryColors: Record<string, string> = {
    identidad: 'bg-brandPink',
    web: 'bg-brandBlue',
    social: 'bg-brandOrange'
};

// Obtener todas las etiquetas únicas
const allTags = [...new Set(projectsData.flatMap(p => p.tags || []))];
---

<Layout title="Portfolio | Arrancandonga">
    <div class="min-h-screen bg-cream overflow-x-hidden w-full flex flex-col">
        <div class="grain"></div>
        <Header />

        <main class="w-full flex-grow relative z-10 pt-4 md:pt-6 pb-16 md:pb-24 px-4 bg-cream">
            <div class="max-w-7xl mx-auto">
                <a href="/" class="inline-block mb-6 md:mb-8 font-display font-bold text-brandDark/60 hover:text-brandOrange flex items-center gap-2 text-sm md:text-base w-max">
                    ← Volver
                </a>

                <div class="text-center mb-8 md:mb-12 px-2">
                    <h1 class="font-display text-4xl sm:text-5xl md:text-6xl font-bold text-brandDark mb-3 md:mb-4">Portfolio</h1>
                    <p class="text-sm md:text-base lg:text-lg text-brandDark/70 max-w-2xl mx-auto mb-6 md:mb-8">
                        Algunos de los proyectos que tuve el placer de acompañar. Cada marca tiene su historia y su proceso.
                    </p>

                    {/* Filtros por categoría */}
                    <div class="flex flex-wrap justify-center gap-2 md:gap-3 mb-4" id="category-filters">
                        {categories.map(cat => (
                            <button
                                data-category={cat.id}
                                class={`filter-btn px-4 py-2 rounded-full font-display font-bold border-2 border-brandDark transition-all text-sm md:text-base ${cat.id === 'todos' ? 'bg-brandDark text-white' : 'bg-white text-brandDark hover:bg-brandPink/20'}`}
                            >
                                {cat.name}
                            </button>
                        ))}
                    </div>

                    {/* Filtros por etiqueta */}
                    <div class="flex flex-wrap justify-center gap-2" id="tag-filters">
                        <button
                            data-tag="all"
                            class={`tag-filter-btn px-3 py-1.5 rounded-full font-medium border border-brandDark/30 transition-all text-xs md:text-sm bg-brandYellow text-brandDark`}
                        >
                            Todas las etiquetas
                        </button>
                        {allTags.map(tag => (
                            <button
                                data-tag={tag}
                                class={`tag-filter-btn px-3 py-1.5 rounded-full font-medium border border-brandDark/30 transition-all text-xs md:text-sm bg-white text-brandDark hover:bg-brandYellow/50`}
                            >
                                {tag}
                            </button>
                        ))}
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-8" id="projects-grid">
                    {projectsData.map((project) => (
                        <a href={`/proyecto/${project.id}`} 
                            class="project-card group bg-white rounded-2xl md:rounded-3xl border-3 md:border-4 border-brandDark overflow-hidden hover:shadow-[8px_8px_0px_#27272A] transition-all transform hover:-translate-y-2 cursor-pointer block"
                            data-category={project.category}
                            data-tags={JSON.stringify(project.tags || [])}
                        >
                            <div class="aspect-[4/3] overflow-hidden bg-brandPink/20 relative">
                                <img
                                    src={project.thumbnail || project.image1}
                                    alt={project.title}
                                    class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-500"
                                />
                                {/* Categoría - esquina superior derecha */}
                                <div class="absolute top-3 right-3 md:top-4 md:right-4">
                                    <span class={`${categoryColors[project.category] || 'bg-white'} px-2 py-0.5 md:px-3 md:py-1 rounded-full border-2 border-brandDark text-xs font-display font-bold uppercase`}>
                                        {categories.find(c => c.id === project.category)?.name}
                                    </span>
                                </div>
                                {/* Etiquetas - esquina superior izquierda */}
                                {project.tags && project.tags.length > 0 && (
                                    <div class="absolute top-3 left-3 md:top-4 md:left-4 flex flex-wrap gap-1 max-w-[60%]">
                                        {project.tags.slice(0, 2).map((tag) => (
                                            <span class="bg-white/90 backdrop-blur-sm px-2 py-0.5 rounded-full border border-brandDark/50 text-[10px] md:text-xs font-medium text-brandDark">
                                                {tag}
                                            </span>
                                        ))}
                                        {project.tags.length > 2 && (
                                            <span class="bg-white/90 backdrop-blur-sm px-2 py-0.5 rounded-full border border-brandDark/50 text-[10px] md:text-xs font-medium text-brandDark">
                                                +{project.tags.length - 2}
                                            </span>
                                        )}
                                    </div>
                                )}
                            </div>
                            <div class="p-4 md:p-6">
                                <h3 class="font-display text-xl md:text-2xl font-bold text-brandDark mb-1 md:mb-2">{project.title}</h3>
                                <p class="text-brandDark/70 mb-3 md:mb-4 text-xs md:text-sm">{project.desc}</p>
                                
                                {/* Todas las etiquetas visibles */}
                                {project.tags && project.tags.length > 0 && (
                                    <div class="flex flex-wrap gap-1.5 mb-3 md:mb-4">
                                        {project.tags.map((tag) => (
                                            <span class="bg-brandYellow/30 px-2 py-0.5 rounded text-[10px] md:text-xs font-medium text-brandDark">
                                                {tag}
                                            </span>
                                        ))}
                                    </div>
                                )}
                                
                                <div class="border-t-2 border-brandDark/10 pt-3 md:pt-4 mt-3 md:mt-4 flex justify-between items-center">
                                    <p class="text-xs md:text-sm text-brandDark/60 italic max-w-[80%] truncate">"{project.clientReview}"</p>
                                    <Icon name="ArrowRight" />
                                </div>
                            </div>
                        </a>
                    ))}
                </div>
            </div>
        </main>
        
        <Footer />
    </div>
</Layout>

<script>
    const filterBtns = document.querySelectorAll('.filter-btn');
    const tagFilterBtns = document.querySelectorAll('.tag-filter-btn');
    const projectCards = document.querySelectorAll('.project-card');
    
    let currentCategory = 'todos';
    let currentTag = 'all';

    function filterProjects() {
        projectCards.forEach(card => {
            const cardCategory = card.getAttribute('data-category');
            const cardTags = JSON.parse(card.getAttribute('data-tags') || '[]');
            
            const categoryMatch = currentCategory === 'todos' || cardCategory === currentCategory;
            const tagMatch = currentTag === 'all' || cardTags.includes(currentTag);
            
            if (categoryMatch && tagMatch) {
                (card as HTMLElement).style.display = 'block';
                card.animate([
                    { opacity: 0, transform: 'scale(0.95)' },
                    { opacity: 1, transform: 'scale(1)' }
                ], {
                    duration: 300,
                    easing: 'ease-out'
                });
            } else {
                (card as HTMLElement).style.display = 'none';
            }
        });
    }

    // Filtros por categoría
    filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            currentCategory = btn.getAttribute('data-category') || 'todos';

            // Update active state of buttons
            filterBtns.forEach(b => {
                b.classList.remove('bg-brandDark', 'text-white');
                b.classList.add('bg-white', 'text-brandDark');
            });
            btn.classList.add('bg-brandDark', 'text-white');
            btn.classList.remove('bg-white', 'text-brandDark');

            filterProjects();
        });
    });
    
    // Filtros por etiqueta
    tagFilterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            currentTag = btn.getAttribute('data-tag') || 'all';

            // Update active state of buttons
            tagFilterBtns.forEach(b => {
                b.classList.remove('bg-brandYellow', 'text-brandDark');
                b.classList.add('bg-white', 'text-brandDark');
            });
            btn.classList.add('bg-brandYellow', 'text-brandDark');
            btn.classList.remove('bg-white', 'text-brandDark');

            filterProjects();
        });
    });
</script>
