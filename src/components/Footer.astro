---
import Icon from './Icon.astro';
import { servicesData } from '../data/servicesData.js';
---

<footer class="bg-brandPurple text-white py-12 md:py-16 px-4 border-t-4 border-brandDark w-full hero-grid relative mt-auto">
    <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 40px 40px;"></div>
    <div class="max-w-7xl mx-auto relative z-10">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 text-center md:text-left items-start">
            <div class="flex flex-col items-center md:items-start">
                <div class="h-28 sm:h-32 md:h-40 mb-4 md:mb-6 w-full flex justify-center md:justify-start">
                    <img
                        src="/arrancandonga-footer-blanco.png"
                        alt="ARRANCANDONGA"
                        class="h-full w-auto object-contain"
                        width="400"
                        height="400"
                        loading="lazy"
                    />
                </div>
                <p class="text-white/80 mb-4 md:mb-6 max-w-sm text-sm md:text-base">Estratégico y con propósito para emprendedoras que quieren destacar.</p>
                <div class="flex gap-3 justify-center md:justify-start">
                    <a href="https://www.instagram.com/arrancandonga_uy/" target="_blank" rel="noopener noreferrer" aria-label="Ver Instagram de Arrancandonga" class="w-10 h-10 md:w-12 md:h-12 bg-brandPink rounded-full flex items-center justify-center border-2 border-[#303030] hover:scale-110 transition-transform text-[#303030]">
                        <Icon name="Instagram" class="w-5 h-5 md:w-6 md:h-6" />
                    </a>
                    <a href="https://wa.me/59899928009" target="_blank" rel="noopener noreferrer" aria-label="Contactar por WhatsApp" class="w-10 h-10 md:w-12 md:h-12 bg-brandGreen rounded-full flex items-center justify-center border-2 border-[#303030] hover:scale-110 transition-transform text-white">
                        <Icon name="WhatsApp" class="w-5 h-5 md:w-6 md:h-6" />
                    </a>
                </div>
            </div>

            <div class="flex flex-col items-center md:items-center">
                <h4 class="font-display font-bold text-brandYellow mb-4 md:mb-6 uppercase tracking-wider text-xs md:text-sm">Servicios</h4>
                <ul class="space-y-2 md:space-y-3 text-white/80 text-sm md:text-base">
                    {servicesData.slice(0, 4).map(s => (
                        <li><a href={`/servicios/${s.id}`} class="hover:text-white transition-colors hover:underline">{s.title}</a></li>
                    ))}
                </ul>
            </div>

            <div class="flex flex-col items-center md:items-end text-center md:text-right">
                <h4 class="font-display font-bold text-brandYellow mb-4 md:mb-6 uppercase tracking-wider text-xs md:text-sm">Contacto</h4>
                <ul class="space-y-2 md:space-y-3 text-white/80 text-sm md:text-base">
                    <li class="font-display text-base md:text-lg font-bold text-white">+598 99 928 009</li>
                    <li>hola@arrancandonga.com</li>
                    <li class="pt-2">
                        <a href="https://calendly.com/arrancandonga-estudiocreativo/conocernos-mejor" target="_blank" class="inline-flex items-center gap-2 text-brandYellow hover:text-white transition-colors font-medium">
                            Agendar reunión →
                        </a>
                    </li>
                </ul>
            </div>
        </div>

        <div class="mt-10 md:mt-16 pt-6 md:pt-8 border-t border-white/20 text-center">
            <p class="text-white/60 text-xs md:text-sm">© 2026 Arrancandonga. Con amor y estrategia</p>
        </div>
    </div>
</footer>

<a href="https://wa.me/59899928009" target="_blank" rel="noopener noreferrer" aria-label="Contactar por WhatsApp"
    class="fixed bottom-4 right-4 md:bottom-6 md:right-6 z-50 bg-brandGreen text-white p-3 md:p-4 rounded-full border-2 border-brandDark hover:scale-110 transition-transform flex items-center justify-center">
    <Icon name="WhatsApp" class="w-6 h-6 md:w-7 md:h-7" />
</a>
