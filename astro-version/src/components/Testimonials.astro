---
import Icon from './Icon.astro';

const testimonials = [
    { text: "Arrancandonga entendió exactamente lo que quería transmitir. Mi marca ahora se ve profesional y me siento orgullosa de mostrarla.", author: "María", company: "Fika", bg: "bg-brandOrange", rotate: "-rotate-2" },
    { text: "El proceso fue súper claro y cercano. No solo quedé con una marca hermosa sino con estrategia para seguir creciendo.", author: "Lucía", company: "Luna Verde", bg: "bg-brandYellow", rotate: "rotate-2" },
    { text: "Finalmente dejé de improvisar en redes. El contenido tiene dirección y estoy vendiendo más que nunca.", author: "Camila", company: "María Paz", bg: "bg-brandBlue", rotate: "-rotate-1" }
];
---

<section class="py-16 md:py-24 px-4 bg-brandPink relative overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 40px 40px;"></div>

    <div class="max-w-7xl mx-auto relative z-10">
        <div class="flex items-center justify-center gap-2 md:gap-4 mb-10 md:mb-16 px-2">
            <div class="w-8 h-8 md:w-10 animate-spin-slow flex-shrink-0">
                <Icon name="Star" />
            </div>
            <h2 class="font-display text-2xl sm:text-3xl md:text-5xl lg:text-6xl font-bold text-brandDark text-center">
                Esto dicen mis clientas 💛
            </h2>
            <div class="w-8 h-8 md:w-10 animate-spin-slow flex-shrink-0" style="animation-direction: reverse;">
                <Icon name="Star" />
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-8">
            {testimonials.map((t) => (
                <div class={`${t.bg} ${t.rotate} rounded-2xl md:rounded-3xl p-5 md:p-8 border-3 md:border-4 border-brandDark transform hover:rotate-0 hover:scale-105 transition-all duration-300`}>
                    <div class="flex gap-1 mb-3 md:mb-4">
                        {[1, 2, 3, 4, 5].map(_ => (
                            <svg class="w-4 h-4 md:w-5 md:h-5 text-brandDark fill-current" viewBox="0 0 20 20">
                                <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z" />
                            </svg>
                        ))}
                    </div>
                    <p class="text-brandDark font-medium text-sm md:text-lg mb-4 md:mb-6 leading-relaxed">"{t.text}"</p>
                    <div class="flex items-center gap-3 pt-3 md:pt-4 border-t-2 border-brandDark/20">
                        <div class="w-10 h-10 md:w-12 md:h-12 rounded-full bg-white border-2 border-brandDark flex items-center justify-center font-display font-bold text-base md:text-xl flex-shrink-0">
                            {t.author[0]}
                        </div>
                        <div class="min-w-0">
                            <p class="font-display font-bold text-brandDark text-sm md:text-base truncate">{t.author}</p>
                            <p class="text-brandDark/60 text-xs md:text-sm font-medium">{t.company}</p>
                        </div>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
